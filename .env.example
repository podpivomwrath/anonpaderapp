# --- VK Callback API ---
# Токен сообщества: Управление -> Настройки -> Работа с API -> Ключи доступа
VK_TOKEN=
# ID сообщества (число, без минуса)
VK_GROUP_ID=0
# Строка подтверждения: Работа с API -> Callback API -> "Строка, которую должен вернуть сервер"
VK_CONFIRMATION_CODE=
# Секретный ключ (там же, поле "Секретный ключ"); если пусто — проверка отключена
VK_SECRET=

# --- Режим: polling (LongPoll, без публичного URL) | callback (нужен туннель/VPS)
BOT_MODE=polling

# --- Веб-сервер ---
HOST=0.0.0.0
PORT=8080

# --- Хранилища (значения совпадают с docker-compose.yml) ---
DATABASE_URL=postgresql+asyncpg://mmo:mmo@localhost:5432/mmo
REDIS_URL=redis://localhost:6379/0

# --- Бой ---
# Окно хода группового PvP в секундах (PvE — без таймера)
COMBAT_TICK_WINDOW_SECONDS=60

# --- VK Mini App (хаб персонажа) ---
# Секретный ключ приложения: vk.com/editapp -> ваше приложение -> "Настройки" (НЕ Callback-секрет)
VK_MINIAPP_SECRET=
# Ссылка на мини-апп для кнопки в боте; заполнить после создания приложения в VK
VK_MINIAPP_URL=
# Origin фронтенда для CORS (в проде — домен VK-хостинга статики, в разработке — свой туннель)
VK_MINIAPP_ORIGIN=*
# Сервисный ключ приложения (Service Token) — пока нигде в коде не используется,
# задел на будущие серверные вызовы VK API от имени приложения
VK_SERVICE_KEY=

LOG_LEVEL=INFO
